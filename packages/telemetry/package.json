{
  "name": "rh-telemetry",
  "version": "1.0.0",
  "description": "Real-time monitoring dashboard for Claude Code CLI sessions",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/toolbeltross/rh-claude-framework",
    "directory": "packages/telemetry"
  },
  "keywords": [
    "claude",
    "claude-code",
    "telemetry",
    "dashboard",
    "monitoring"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "rh-telemetry": "bin/rh-telemetry.js"
  },
  "files": [
    "bin/",
    "server/",
    "scripts/*.js",
    "dist/"
  ],
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "vite",
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "start": "node server/index.js",
    "setup-hooks": "node scripts/setup-hooks.js",
    "start:bg": "node scripts/start-bg.js",
    "install-skills": "node scripts/install-skills.js",
    "test": "node tests/run.js unit integration",
    "test:unit": "node tests/run.js unit",
    "test:integration": "node tests/run.js integration",
    "test:browser": "node tests/run.js browser",
    "test:all": "node tests/run.js unit integration browser",
    "test:visual": "node tests/visual-parity/run.js",
    "install-git-hooks": "node scripts/install-git-hooks.js"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.3",
    "tailwindcss": "^4.1.3",
    "vite": "^6.4.1"
  }
}